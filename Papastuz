local function PlaySound(soundId, volume)
    volume = volume or 0.5
    if not soundId or soundId == "" then soundId = DEFAULT_TEAM_SOUND end
    local s = Instance.new("Sound", SoundService)
    s.SoundId = soundId
    s.Volume = volume
    s:Play()
    game.Debris:AddItem(s, 2)
end

