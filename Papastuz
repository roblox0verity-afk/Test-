    plusBtn.TextSize = 18
    plusBtn.Text = "+"
    Instance.new("UICorner", plusBtn).CornerRadius = UDim.new(0.2,0)

    local current = defaultVal
    local function UpdateDisplay()
        label.Text = name..": "..string.format("%.2f", current)
        local key = name:gsub(" ","")
        if _G.Settings[key] ~= nil then _G.Settings[key] = current end
    end
    UpdateDisplay()

