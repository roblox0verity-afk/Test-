-- Vareware Notice
local Players = game:GetService("Players")
local PlayerGui = Players.LocalPlayer:WaitForChild("PlayerGui")

-- Remove old UI if present
if PlayerGui:FindFirstChild("VarewareNotice") then PlayerGui.VarewareNotice:Destroy() end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "VarewareNotice"
ScreenGui.IgnoreGuiInset = true
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = PlayerGui

-- Background box
local Box = Instance.new("Frame")
Box.Size = UDim2.new(0, 380, 0, 180)
Box.Position = UDim2.new(0.5, -190, 0.5, -90)
Box.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Box.BorderSizePixel = 0
local Corner = Instance.new("UICorner", Box)
Corner.CornerRadius = UDim.new(0.08, 0)
Box.Parent = ScreenGui

-- Text
local Message = Instance.new("TextLabel", Box)
Message.Size = UDim2.new(1, 0, 1, 0)
Message.BackgroundTransparency = 1
Message.Font = Enum.Font.GothamBold
Message.TextColor3 = Color3.new(1, 1, 1)
Message.TextSize = 24
Message.TextWrapped = true
Message.Text = "Vareware is now paid buy now"
