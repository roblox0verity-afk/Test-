        PlaySound(SOUND_BUTTON_TAP)
        current = math.max(minVal, current - step); UpdateDisplay()
    end)
    plusBtn.MouseButton1Click:Connect(function()
        PlaySound(SOUND_BUTTON_TAP)
        current = math.min(maxVal, current + step); UpdateDisplay()
    end)
end

