-- Shared Helpers
local function GetClosestPlayer(query)
    query=query:lower(); if query=="" then return nil end
    local bestPlr,bestScore=nil,-1
    local myRoot=Character and Character:FindFirstChild("HumanoidRootPart")
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr==LocalPlayer then continue end
        local n1=plr.Name:lower(); local n2=plr.DisplayName:lower(); local score=0
        if n1:find(query,1,true) then score+=2+(#query/#n1) end
        if n2:find(query,1,true) then score+=2+(#query/#n2) end
        if score>bestScore and myRoot then
            local c=plr.Character; local hrp=c and c:FindFirstChild("HumanoidRootPart")
            if hrp then local dist=(myRoot.Position-hrp.Position).Magnitude; bestScore=score; bestPlr=plr end
        end
    end
    return bestPlr
end

