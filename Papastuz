-- Config Functions
local function RefreshConfigDropdown()
    for _,c in ipairs(DropdownScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    local configs = ConfigRoot:GetChildren()
    table.sort(configs,function(a,b) return a.Name<b.Name end)
    for _,cfg in ipairs(configs) do
        if cfg:IsA("Folder") then
            local btn=Instance.new("TextButton",DropdownScroll)
            btn.Size=UDim2.new(1,0,0,30); btn.BackgroundTransparency=1-OPACITY_70; btn.BackgroundColor3=C_BLACK
            btn.Font=Enum.Font.Gotham; btn.TextColor3=C_WHITE; btn.TextSize=14; btn.Text=cfg.Name
            btn.MouseButton1Click:Connect(function() ConfigDropdown.Text=cfg.Name; DropdownFrame.Visible=false end)
        end
    end
    DropdownScroll.CanvasSize=UDim2.new(0,0,0,DropdownLayout.AbsoluteContentSize.Y)
end

local function SaveConfig(name)
    if not name or name=="" then ConfigStatus.Text="Enter a name"; ConfigStatus.TextColor3=C_RED; return end
    local cfgFolder = ConfigRoot:FindFirstChild(name) or Instance.new("Folder",ConfigRoot)
    cfgFolder.Name=name
    for k,v in pairs(_G.Settings) do
        if type(v)~="boolean" then
            local sv=cfgFolder:FindFirstChild(k) or Instance.new("StringValue",cfgFolder)
            sv.Name=k; sv.Value=tostring(v)
        else
            local bv=cfgFolder:FindFirstChild(k) or Instance.new("BoolValue",cfgFolder)
            bv.Name=k; bv.Value=v
        end
    end
    AutoLoadFlag.Value=_G.Settings.AutoLoadConfig
    LastLoaded.Value=name
    _G.Settings.LastLoadedConfig=name
    RefreshConfigDropdown()
    ConfigStatus.Text="Saved: "..name; ConfigStatus.TextColor3=C_GREEN
    task.delay(1.5,function() ConfigStatus.Text="Ready" end)
end

local function LoadConfig(name)
    local cfg=ConfigRoot:FindFirstChild(name)
    if not cfg then ConfigStatus.Text="Not found"; ConfigStatus.TextColor3=C_RED; return end
    for k in pairs(_G.Settings) do
        local sv=cfg:FindFirstChild(k)
        if sv then
            if sv:IsA("BoolValue") then _G.Settings[k]=sv.Value
            else local num=tonumber(sv.Value); if num then _G.Settings[k]=num end end
        end
    end
    AutoLoadFlag.Value=_G.Settings.AutoLoadConfig
    LastLoaded.Value=name
    UpdateAimToggle()
    ConfigStatus.Text="Loaded: "..name; ConfigStatus.TextColor3=C_GREEN
    task.delay(1.5,function() ConfigStatus.Text="Ready" end)
end

-- Auto‑load on execute
if AutoLoadFlag.Value and LastLoaded.Value~="" then
    _G.Settings.AutoLoadConfig=true
    _G.Settings.LastLoadedConfig=LastLoaded.Value
    LoadConfig(LastLoaded.Value)
end

