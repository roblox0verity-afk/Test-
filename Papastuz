            data.Tag.Dist.Text = math.floor((myPos - char.HumanoidRootPart.Position).Magnitude).."m"
        end
    end
    for _,data in pairs(_G.Team) do
        local plr = data.Player; local char = plr and plr.Character
        local valid = char and IsValidHuman(char:FindFirstChild("Humanoid"))
        data.Highlight.Adornee = valid and char or nil
