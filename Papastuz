        if valid then
            data.Tag.Gui.Adornee = char:FindFirstChild("HumanoidRootPart")
            data.Tag.Dist.Text = math.floor((myPos - char.HumanoidRootPart.Position).Magnitude).."m"
        end
    end
end)

