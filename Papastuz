-- CORE UTILS
local function CanSee(Part)
    local Params = RaycastParams.new()
    Params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    Params.FilterType = Enum.RaycastFilterType.Exclude
    local Res = Workspace:Raycast(Camera.CFrame.Position, Part.Position - Camera.CFrame.Position, Params)
    return not Res or Res.Instance == Part or Res.Instance:IsDescendantOf(Part.Parent)
end

local function IsPlayerRagdolled()
    local Char = LocalPlayer.Character
    if not Char then return true end
    local Hum = Char:FindFirstChild("Humanoid")
    if not Hum then return true end
    return Hum.PlatformStand or Hum.Sit or Char:FindFirstChild("Ragdoll") or Char:FindFirstChild("IsRagdolled")
end

local function IsValidTarget(Char)
    if not Char then return false end
    local H = Char:FindFirstChild("Humanoid")
    if not H or H.Health <= 0 then return false end
    if H.PlatformStand or H.Sit then return false end
    if Char:FindFirstChild("Ragdoll") or Char:FindFirstChild("IsRagdolled") then return false end
    return true
end

-- ✅ FIXED PART DETECTION
local function GetTargetPart(Char)
    if not Char then return Char:FindFirstChild("Head") end
    local Sel = _G.TargetPart
    if Sel == "Torso" then
        return Char:FindFirstChild("Torso") or Char:FindFirstChild("UpperTorso") or Char:FindFirstChild("LowerTorso") or Char:FindFirstChild("Head")
    end
    if Sel == "Left Arm" then
        return Char:FindFirstChild("Left Arm") or Char:FindFirstChild("LeftUpperArm") or Char:FindFirstChild("LeftHand") or Char:FindFirstChild("Head")
    end
    if Sel == "Right Arm" then
        return Char:FindFirstChild("Right Arm") or Char:FindFirstChild("RightUpperArm") or Char:FindFirstChild("RightHand") or Char:FindFirstChild("Head")
    end
    if Sel == "Left Leg" then
        return Char:FindFirstChild("Left Leg") or Char:FindFirstChild("LeftUpperLeg") or Char:FindFirstChild("LeftFoot") or Char:FindFirstChild("Head")
    end
    if Sel == "Right Leg" then
        return Char:FindFirstChild("Right Leg") or Char:FindFirstChild("RightUpperLeg") or Char:FindFirstChild("RightFoot") or Char:FindFirstChild("Head")
    end
    return Char:FindFirstChild(Sel) or Char:FindFirstChild("Head")
end

local function UpdateRandomPart()
    if not _G.RandomPartEnabled or not CurrentTarget then return end
    if os.clock() - LastRandomChange >= 0.5 then
        LastRandomChange = os.clock()
        _G.TargetPart = AllParts[Random.new():NextInteger(1, #AllParts)]
        if PartBtn then PartBtn.Text = _G.TargetPart end
    end
end
