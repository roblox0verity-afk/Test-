-- Respawn & Helpers
LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character=newChar; Humanoid=newChar:WaitForChild("Humanoid")
    HumanoidRootPart=newChar:WaitForChild("HumanoidRootPart")
end)
local function IsValidHuman(hum)
    return hum and hum.Health>0 and not hum.PlatformStand
        and hum:GetState()~=Enum.HumanoidStateType.FallingDown
        and not hum:FindFirstChild("Ragdoll")
end
local function HasLineOfSight(fromPos, toPart)
    if not toPart then return false end
    RaycastParams.FilterDescendantsInstances={Character}
    local result=Workspace:Raycast(fromPos, toPart.Position-fromPos, RaycastParams)
    return not result or result.Instance:IsDescendantOf(toPart.Parent)
end
local function GetBestTarget()
    if not _G.Settings.AimlockEnabled or not IsValidHuman(Humanoid) then return nil end
    local bestTorso,bestDist=nil,math.huge
    for uid,data in pairs(_G.Enemies) do
        if data.left then continue end
        local plr=data.player
        if plr and plr~=LocalPlayer then
            local char=plr.Character
            local hum=char and char:FindFirstChild("Humanoid")
            local torso=char and (char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"))
            local hrp=char and char:FindFirstChild("HumanoidRootPart")
            if IsValidHuman(hum) and torso and hrp and HasLineOfSight(HumanoidRootPart.Position,torso) then
                local dist=(Camera.CFrame.Position-torso.Position).Magnitude
                if dist<bestDist then bestDist=dist; bestTorso=torso end
            end
        end
    end
    return bestTorso
end

-- Main Loop
RunService.RenderStepped:Connect(function()
    if not Character or not HumanoidRootPart or not Humanoid then return end
    local myRoot=HumanoidRootPart
    local targetTorso=GetBestTarget()

    -- Auto‑zoom
    if _G.Settings.AimlockEnabled then
        Camera.FieldOfView = targetTorso and _G.Settings.ZoomFOV or _G.Settings.NormalFOV
    end

    -- Aimlock ONLY enemies
    if targetTorso then
        local targetHRP=targetTorso.Parent:FindFirstChild("HumanoidRootPart")
        local aimPos=targetTorso.Position
        if targetHRP then aimPos += targetHRP.Velocity * _G.Settings.Prediction end
        aimPos += Vector3.new(0,_G.Settings.Offset,0)
        local lookDir=(aimPos-myRoot.Position).Unit
        myRoot.CFrame=CFrame.lookAt(myRoot.Position, myRoot.Position+Vector3.new(lookDir.X,0,lookDir.Z))
        Camera.CFrame=Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position,aimPos), _G.Settings.AimSpeed)
    end

    -- Update ESP/Tags
    for uid,data in pairs(_G.Enemies) do
        local plr=data.player; local hl=_G.Highlights[uid]; local tag=_G.NameTags[uid]
        if not plr then hl:Destroy(); tag.Gui:Destroy(); _G.Enemies[uid]=nil; continue end
        if data.left then hl.Enabled=false; tag.Gui.Enabled=false; continue end
        local c=plr.Character; local hum=c and c:FindFirstChild("Humanoid"); local hrp=c and c:FindFirstChild("HumanoidRootPart")
        if c and IsValidHuman(hum) and hrp then hl.Enabled=true; hl.Adornee=c; tag.Gui.Enabled=true; tag.Gui.Adornee=hrp; tag.Name.Text=plr.DisplayName; tag.Dist.Text=math.floor((myRoot.Position-hrp.Position).Magnitude).." studs"
        else hl.Enabled=false; tag.Gui.Enabled=false end
    end
    for uid,data in pairs(_G.Team) do
        local plr=data.player; local hl=_G.Highlights[uid]; local tag=_G.NameTags[uid]
        if not plr then hl:Destroy(); tag.Gui:Destroy(); _G.Team[uid]=nil; continue end
        if data.left then hl.Enabled=false; tag.Gui.Enabled=false; continue end
        local c=plr.Character; local hum=c and c:FindFirstChild("Humanoid"); local hrp=c and c:FindFirstChild("HumanoidRootPart")
        if c and IsValidHuman(hum) and hrp then hl.Enabled=true; hl.Adornee=c; tag.Gui.Enabled=true; tag.Gui.Adornee=hrp; tag.Name.Text=plr.DisplayName; tag.Dist.Text=math.floor((myRoot.Position-hrp.Position).Magnitude).." studs"
        else hl.Enabled=false; tag.Gui.Enabled=false end
    end
end)

