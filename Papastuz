-- Slider Helper
local function CreatePlusMinus(name,posY,minV,maxV,defV,step)
    local con=Instance.new("Frame",Tab1)
    con.Size=UDim2.new(0.7,0,0,50); con.Position=UDim2.new(0.15,0,posY,0); con.BackgroundTransparency=1
    local lbl=Instance.new("TextLabel",con)
    lbl.Size=UDim2.new(0.6,0,0,20); lbl.BackgroundTransparency=1; lbl.Font=Enum.Font.GothamSemibold
    lbl.TextColor3=C_WHITE; lbl.TextSize=14; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local minus=Instance.new("TextButton",con)
    minus.Size=UDim2.new(0,35,0,35); minus.Position=UDim2.new(0.62,0,0.25,0)
    minus.BackgroundTransparency=1-OP70; minus.BackgroundColor3=C_BLACK; minus.Text="−"
    minus.Font=Enum.Font.GothamBold; minus.TextColor3=C_WHITE; minus.TextSize=18
    Instance.new("UICorner",minus).CornerRadius=UDim.new(0.2,0)
    local plus=Instance.new("TextButton",con)
    plus.Size=UDim2.new(0,35,0,35); plus.Position=UDim2.new(0.82,0,0.25,0)
    plus.BackgroundTransparency=1-OP70; plus.BackgroundColor3=C_BLACK; plus.Text="+"
    plus.Font=Enum.Font.GothamBold; plus.TextColor3=C_WHITE; plus.TextSize=18
    Instance.new("UICorner",plus).CornerRadius=UDim.new(0.2,0)
    local cur=defV
    local function upd() lbl.Text=name..": "..string.format("%.2f",cur); _G.Settings[name:gsub(" ","")]=cur end
    upd()
    minus.MouseButton1Click:Connect(function() PlaySound(SOUND_BUTTON_TAP); cur=math.max(minV,cur-step);upd() end)
    plus.MouseButton1Click:Connect(function() PlaySound(SOUND_BUTTON_TAP); cur=math.min(maxV,cur+step);upd() end)
end
