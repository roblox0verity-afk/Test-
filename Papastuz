-- Get Target Part
local function GetTargetPart(char)
    if not char then return nil end
    if _G.Settings.AimPartMode == "AllParts" then
        local now = os.clock()
        if now - lastPartCycle >= _G.Settings.PartCycleDelay then
            lastPartCycle = now
            currentPartIndex = (currentPartIndex % #ALL_BODY_PARTS) + 1
        end
        return char:FindFirstChild(ALL_BODY_PARTS[currentPartIndex])
    else
        return char:FindFirstChild(_G.Settings.AimPartMode)
    end
end

-- Slot Switcher
local function UpdateSlot()
    if _G.Settings.SlotMode == "None" then return end
    local now = os.clock()
    if _G.Settings.SlotMode == "Loop123" then
        if now - lastSlotCycle >= 1 then
            lastSlotCycle = now
            currentSlot = (currentSlot % 3) + 1
            ContextActionService:SendInput({KeyCode=Enum.KeyCode.One + currentSlot - 1}, true)
            task.wait(0.05)
            ContextActionService:SendInput({KeyCode=Enum.KeyCode.One + currentSlot - 1}, false)
        end
    else
        local num = tonumber(_G.Settings.SlotMode)
        if num and num ~= currentSlot then
            currentSlot = num
            ContextActionService:SendInput({KeyCode=Enum.KeyCode.One + currentSlot - 1}, true)
            task.wait(0.05)
            ContextActionService:SendInput({KeyCode=Enum.KeyCode.One + currentSlot - 1}, false)
        end
    end
end

-- Get Best Target
local function GetBestTarget()
    if not _G.Settings.AimlockEnabled or not IsValidHuman(Humanoid) then return nil end
    local bestPart, bestDist = nil, math.huge
    for _,data in pairs(_G.Enemies) do
        if data.Left then continue end
        local plr = data.Player; if not plr or plr == LocalPlayer then continue end
        local char = plr.Character; if not char then continue end
        local hum = char:FindFirstChild("Humanoid"); local part = GetTargetPart(char)
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if IsValidHuman(hum) and part and hrp and HasLineOfSight(HumanoidRootPart.Position, part) then
            local dist = (Camera.CFrame.Position - part.Position).Magnitude
            if dist < bestDist then bestDist = dist; bestPart = part end
        end
    end
    return bestPart
end

-- Main Loop
RunService.RenderStepped:Connect(function()
    if not Character or not HumanoidRootPart or not Humanoid then return end
    local myPos = HumanoidRootPart.Position
    local targetPart = GetBestTarget()

    -- FOV
    Camera.FieldOfView = _G.Settings.AimlockEnabled and targetPart and _G.Settings.ZoomFOV or _G.Settings.NormalFOV

    -- Aim
    if targetPart then
        local hrp = targetPart.Parent:FindFirstChild("HumanoidRootPart")
        local aimPos = targetPart.Position
        if hrp then aimPos += hrp.Velocity * _G.Settings.Prediction end
        aimPos += Vector3.new(0, _G.Settings.Offset, 0)
        local dir = (aimPos - myPos).Unit
        HumanoidRootPart.CFrame = CFrame.lookAt(myPos, myPos + Vector3.new(dir.X,0,dir.Z))
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, aimPos), _G.Settings.AimSpeed)
        UpdateSlot()
    end

    -- Update ESP
    for _,data in pairs(_G.Enemies) do
        local plr = data.Player; local char = plr and plr.Character
        local valid = char and IsValidHuman(char:FindFirstChild("Humanoid"))
