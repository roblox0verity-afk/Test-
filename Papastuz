-- Shared Helpers
local function GetClosestPlayer(query)
    query = query:lower()
    if query == "" then return nil end
    local best, bestScore = nil, -1
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local n1, n2 = plr.Name:lower(), plr.DisplayName:lower()
        local score = 0
        if n1:find(query,1,true) then score += 2 + (#query/#n1) end
        if n2:find(query,1,true) then score += 2 + (#query/#n2) end
        if score > bestScore and HumanoidRootPart then
            local c = plr.Character; local hrp = c and c:FindFirstChild("HumanoidRootPart")
            if hrp then local dist = (HumanoidRootPart.Position - hrp.Position).Magnitude; bestScore = score; best = plr end
        end
    end
    return best
end

local function IsValidHuman(hum)
    return hum and hum.Health > 0 and not hum.PlatformStand
        and hum:GetState() ~= Enum.HumanoidStateType.FallingDown
        and not hum:FindFirstChild("Ragdoll")
end

local function HasLineOfSight(fromPos, toPart)
    if not toPart then return false end
    RaycastParams.FilterDescendantsInstances = {Character}
    local result = Workspace:Raycast(fromPos, toPart.Position - fromPos, RaycastParams)
    return not result or result.Instance:IsDescendantOf(toPart.Parent)
end

