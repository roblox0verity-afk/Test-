    local c=LocalPlayer.Character; if not c then return true end
    local h=c:FindFirstChildOfClass("Humanoid")
    return not h or h.PlatformStand or h:GetState()==Enum.HumanoidStateType.FallingDown or h.Health<=0
end
local function IsRagdolled(hum)
    return not hum or hum.Health<=0 or hum.PlatformStand or hum:GetState()==Enum.HumanoidStateType.FallingDown
end
local function IsOnScreen(part)
    if not part then return false end
    local pos,onScr=Camera:WorldToViewportPoint(part.Position)
    return onScr and pos.Z>0
end

local function GetBestTarget()
    if not _G.Settings.AimlockEnabled or IsMyRagdolled() then return nil end
    local bestTorso,bestDist=nil,9e99
    for _,uid in ipairs(_G.Enemies) do
        local plr=Players:GetPlayerByUserId(uid)
        if plr and plr~=LocalPlayer then
            local c=plr.Character; if not c then continue end
            local h=c:FindFirstChildOfClass("Humanoid")
            if not IsRagdolled(h) then
                local torso=c:FindFirstChild("UpperTorso") or c:FindFirstChild("Torso")
                local hrp=c:FindFirstChild("HumanoidRootPart")
                if torso and hrp and h.Health>0 then
                    local dist=(Camera.CFrame.Position-torso.Position).Magnitude
                    if dist<bestDist then bestDist=dist; bestTorso=torso end
                end
            end
        end
    end
    return bestTorso
end

-- Main update loop
RunService.RenderStepped:Connect(function()
    local myRoot = Character and Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    -- Aimlock
    local target=GetBestTarget()
    if target then
        local hrp=target.Parent:FindFirstChild("HumanoidRootPart")
        local aimPos=target.Position
        if hrp then aimPos+=hrp.Velocity*_G.Settings.Prediction end
        aimPos+=Vector3.new(0,_G.Settings.Offset,0)
        if _G.Settings.AimSpeed>=0.999 then
            Camera.CFrame=CFrame.lookAt(Camera.CFrame.Position,aimPos)
        else
            Camera.CFrame=Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position,aimPos),_G.Settings.AimSpeed)
        end
    end

    -- Update glow + name/dist/health + pointers for ENEMIES ONLY
    for uid, highlight in pairs(_G.Highlights) do
        local plr = Players:GetPlayerByUserId(uid)
        local tag = _G.NameTags[uid]
        local ptr = _G.Pointers[uid]
        if not plr or not table.find(_G.Enemies, uid) then
            highlight:Destroy()
            if tag then tag.Gui:Destroy() end
            if ptr then ptr:Destroy() end
            _G.Highlights[uid] = nil
            _G.NameTags[uid] = nil
            _G.Pointers[uid] = nil
            continue
        end
        local char = plr.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hum or not hrp or hum.Health <= 0 then
            highlight.Adornee = nil
            highlight.Enabled = false
            if tag then tag.Gui.Enabled = false end
            if ptr then ptr.Visible = false end
            continue
        end

        -- Glow: always on, no range limit
        highlight.Enabled = true
        highlight.Adornee = char

        -- Distance calculation
        local dist = math.floor((myRoot.Position - hrp.Position).Magnitude)

        -- Billboard: Name + Distance + Health
        if tag then
            tag.Gui.Enabled = true
            tag.Gui.Adornee = hrp
            tag.Name.Text = plr.DisplayName
            tag.Dist.Text = dist.." studs"
            tag.Health.Size = UDim2.new(math.clamp(hum.Health / hum.MaxHealth, 0, 1), 0, 1, 0)
        end

        -- Red Pointer for off-screen
        if ptr then
            local onScreen, screenPos = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen and screenPos.Z > 0 then
                ptr.Visible = false
            else
                ptr.Visible = true
                -- Calculate clamped edge position + rotation
                local dir = Vector2.new(screenPos.X - ScreenSize.X/2, screenPos.Y - ScreenSize.Y/2).Unit
                local angle = math.atan2(dir.Y, dir.X)
                ptr.Rotation = math.deg(angle)
                local edgePos = Vector2.new(
                    math.clamp(screenPos.X, EdgeOffset, ScreenSize.X - EdgeOffset),
                    math.clamp(screenPos.Y, EdgeOffset, ScreenSize.Y - EdgeOffset)
                )
                ptr.Position = UDim2.new(0, edgePos.X, 0, edgePos.Y)
            end
        end
    end
end)
