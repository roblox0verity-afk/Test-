-- Add row with glow + name/dist/health + pointer if enemy
local function AddPlayerRow(plr, isEnemy)
    if not plr or _G.PlayerCache[plr.UserId] then return end
    _G.PlayerCache[plr.UserId] = true

    local row = Instance.new("Frame", ListContainer)
    row.Size = UDim2.new(1,0,0,50)
    row.BackgroundTransparency = 1 - OPACITY_70
    row.BackgroundColor3 = C_BLACK
    row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0.08,0)

    local NameLabel = Instance.new("TextLabel", row)
    NameLabel.Size = UDim2.new(0.8,0,1,0)
    NameLabel.Position = UDim2.new(0.05,0,0,0)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Font = Enum.Font.GothamSemibold
    NameLabel.TextColor3 = C_WHITE
    NameLabel.TextSize = 14
    NameLabel.Text = plr.DisplayName.." (@"..plr.Name..")"
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left

    local RemoveBtn = Instance.new("TextButton", row)
    RemoveBtn.Size = UDim2.new(0,30,0,30)
    RemoveBtn.Position = UDim2.new(0.88,0,0.2,0)
    RemoveBtn.BackgroundTransparency = 0.8
    RemoveBtn.Text = "X"
    RemoveBtn.Font = Enum.Font.GothamBold
    RemoveBtn.TextColor3 = C_RED
    RemoveBtn.TextSize = 16
    RemoveBtn.AutoButtonColor = false

    -- Only glow + name/dist/health + pointer for ENEMIES
    if isEnemy then
        _G.Highlights[plr.UserId] = CreateEnemyGlow()
        _G.NameTags[plr.UserId] = CreateNameHealth()
        _G.Pointers[plr.UserId] = CreatePointer()
        _G.Pointers[plr.UserId].Parent = ScreenGui
    end

    -- Cleanup
    local function RemoveEntry()
        _G.PlayerCache[plr.UserId] = nil
        if isEnemy then
            for i = #_G.Enemies,1,-1 do if _G.Enemies[i] == plr.UserId then table.remove(_G.Enemies,i) end end
            if _G.Highlights[plr.UserId] then _G.Highlights[plr.UserId]:Destroy() end
            if _G.NameTags[plr.UserId] then _G.NameTags[plr.UserId].Gui:Destroy() end
            if _G.Pointers[plr.UserId] then _G.Pointers[plr.UserId]:Destroy() end
            _G.Highlights[plr.UserId] = nil
            _G.NameTags[plr.UserId] = nil
            _G.Pointers[plr.UserId] = nil
        else
            for i = #_G.Team,1,-1 do if _G.Team[i] == plr.UserId then table.remove(_G.Team,i) end end
        end
        row:Destroy()
        ListContainer.CanvasSize = UDim2.new(0,0,0,ListLayout.AbsoluteContentSize.Y)
    end
    RemoveBtn.MouseButton1Click:Connect(RemoveEntry)
    row.Destroying:Connect(RemoveEntry)

    ListContainer.CanvasSize = UDim2.new(0,0,0,ListLayout.AbsoluteContentSize.Y)
end

