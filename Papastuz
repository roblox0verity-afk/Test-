local function RunAutoJump()
    if not _G.AutoJumpEnabled or not _G.AimlockEnabled or not CurrentTarget then return end
    local Char = LocalPlayer.Character
    if not Char then return end
    local Hum = Char:FindFirstChild("Humanoid")
    if not Hum or Hum.PlatformStand or Hum.Sit then return end
    if Hum.FloorMaterial ~= Enum.Material.Air then
        Hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

local function RunAutoShoot()
    if not _G.AutoShootEnabled or not _G.AimlockEnabled then return end
    if not CurrentTarget then return end
    if IsPlayerRagdolled() then return end
    if os.clock() - LastShootTime < 0.05 then return end
    local TChar = CurrentTarget.Character
    if not TChar or not IsValidTarget(TChar) then return end
    local AimPart = GetTargetPart(TChar)
    if not AimPart then return end
    if _G.WallCheckEnabled and not CanSee(AimPart) then return end
    local Dist = (AimPart.Position - Camera.CFrame.Position).Magnitude
    if Dist < _G.AutoShootMinDist or Dist > _G.AutoShootMaxDist then return end
    local Tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not Tool then return end
    Tool:Activate()
    LastShootTime = os.clock()
end

-- MAIN AIM LOOP
RunService.RenderStepped:Connect(function(Delta)
    if MenuOpen then CrosshairRot += Delta * 180; Crosshair.Rotation = CrosshairRot % 360 end
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    if IsPlayerRagdolled() then CurrentTarget = nil return end

    local TargetPos, BestDist, Center = nil, math.huge, Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local MaxFOV = _G.FOVEnabled and _G.FOVSize or math.huge
    CurrentTarget = nil

    local function Check(Ply)
        if not Ply or not Ply.Character or not IsValidTarget(Ply.Character) then return end
        local AimPart = GetTargetPart(Ply.Character)
        local Pos, Vis = Camera:WorldToScreenPoint(AimPart.Position)
        local D = (Vector2.new(Pos.X,Pos.Y)-Center).Magnitude
        local PassFOV = _G.ThreeSixtyEnabled or (Vis and D < MaxFOV)
        if PassFOV and (not _G.WallCheckEnabled or CanSee(AimPart)) and D < BestDist then
            BestDist = D
            CurrentTarget = Ply
            TargetPos = _G.PredictionEnabled and AimPart.Position + Ply.Character.HumanoidRootPart.Velocity * (_G.AimPrediction/100) * 0.15 or AimPart.Position
        end
    end

    if _G.AimlockEnabled then
        if next(PriorityList) then
            for _, D in pairs(PriorityList) do Check(D.Player) end
        else
            for _, P in pairs(Players:GetPlayers()) do if P ~= LocalPlayer then Check(P) end end
        end
        if TargetPos then
            if _G.AimSpeedEnabled then
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, TargetPos), _G.AimSpeed / 100)
            else
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, TargetPos)
            end
        end
    end

    UpdateRandomPart()
    RunAutoJump()
    RunAutoShoot()

    if _G.AutoAirEnabled and CurrentTarget and CurrentTarget.Character then
        local THum = CurrentTarget.Character:FindFirstChild("Humanoid")
        if THum then
            if not JumpData[CurrentTarget.UserId] then JumpData[CurrentTarget.UserId] = {OnGround = true, Shot = false} end
            local D = JumpData[CurrentTarget.UserId]
            local Air = THum.FloorMaterial == Enum.Material.Air
            if D.OnGround and Air and not D.Shot then
                if CanSee(GetTargetPart(CurrentTarget.Character)) then
                    local T = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                    if T then T:Activate() end
                end
                D.Shot = true
            elseif not Air then D.Shot = false end
            D.OnGround = not Air
        end
    end

    local SC = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _,D in pairs(PriorityList) do
        local P = D.Player
        if P and P.Character and P.Character.PrimaryPart then
            local Pos, Vis = Camera:WorldToScreenPoint(P.Character.PrimaryPart.Position)
            local Show = _G.PriorityESPEnabled and Vis
            -- ✅ USE NEW TOGGLES
            D.Tracer.Visible = Show and _G.TracerEnabled
            D.NameTag.Visible = Show and _G.NameTagEnabled
            if Show then
                D.Tracer.From = SC; D.Tracer.To = Vector2.new(Pos.X, Pos.Y)
                D.NameTag.Position = Vector2.new(Pos.X, Pos.Y-22)
                D.NameTag.Text = P.Name
            end
        end
    end

    local HasT = CurrentTarget and _G.StatusHudEnabled
    StatusHud.Visible = HasT
    if HasT then
        local H = CurrentTarget.Character:FindFirstChild("Humanoid")
        HudName.Text = CurrentTarget.Name
        HudPart.Text = "Target: ".._G.TargetPart
        HudDist.Text = "Distance: "..math.floor((GetTargetPart(CurrentTarget.Character).Position-Camera.CFrame.Position).Magnitude)
        pcall(function() Avatar.Image = "rbxthumb://type=AvatarHeadShot&id="..CurrentTarget.UserId.."&w=150&h=150" end)
        if H then HealthBar.Size=UDim2.new(math.max(0,H.Health)/math.max(1,H.MaxHealth),0,1,0); HudHealthTxt.Text=math.floor(H.Health).." / "..math.floor(H.MaxHealth) end
    end
    MainTargetName.Text = CurrentTarget and CurrentTarget.Name:upper() or "NO TARGET"
end)
